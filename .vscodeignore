# Files excluded from the .vsix package.
# The packager includes everything not listed here.
# Only dist/ and the manifest are needed at runtime.

# Source — not needed at runtime; bundles are in dist/
src/
tests/
scripts/

# Sprite SOURCE tree — the build copies the needed PNG frames + bakes the
# manifest into dist/webview/; the authoring source (animations.json +
# _pixellab_anims rotations) is not needed at runtime (86ca191uy).
assets/

# Dev tooling
.github/
.claude/
.eslintrc*
.eslintignore
.prettierrc*
tsconfig*.json
vitest*.config.ts
esbuild.config.mjs

# Team / planning docs — not extension content
team/
docs/

# Build artifacts that are NOT the extension bundles
dist/cli/

# Layer-3 (@vscode/test-electron) compiled test output + VS Code cache
out/
.vscode-test/

# Environment / editor
.env
.vscode/
*.vsix

# Node modules — vsce packs the extension; deps are bundled by esbuild
node_modules/

# Working notes / scratch files
.scratch/

# Misc
*.map
.gitignore
.gitkeep
*.md
!README.md
