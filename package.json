{
  "name": "claudeteam",
  "displayName": "ClaudeTeam",
  "version": "0.0.1",
  "description": "Real-time dashboard for orchestrated Claude Code agent teams.",
  "publisher": "claudeteam",
  "license": "UNLICENSED",
  "type": "module",
  "private": true,
  "main": "dist/extension/main.cjs",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TSandvaer/ClaudeTeam.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:claudeteam.dashboard"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeteam-container",
          "title": "ClaudeTeam",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "claudeteam-container": [
        {
          "type": "webview",
          "id": "claudeteam.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeteam.refresh",
        "title": "ClaudeTeam: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeteam.openRoster",
        "title": "ClaudeTeam: Open Roster",
        "icon": "$(list-unordered)"
      },
      {
        "command": "claudeteam.openAgentTranscript",
        "title": "ClaudeTeam: Open Agent Transcript",
        "icon": "$(book)"
      }
    ],
    "configuration": {
      "title": "ClaudeTeam",
      "properties": {
        "claudeteam.rosterPath": {
          "type": "string",
          "default": "",
          "description": "Override path to teams.yaml roster file. Empty string uses the default global location (~/.claudeteam/teams.yaml) with per-project fallback."
        },
        "claudeteam.pollIntervalMs": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "description": "How often (in milliseconds) to poll ~/.claude/ for agent state updates."
        },
        "claudeteam.rosterPollIntervalMs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Fallback polling cadence (in milliseconds) for the roster YAML watcher. 0 = OFF (rely on VS Code's FileSystemWatcher). Set to a positive value (e.g. 5000) only if the FileSystemWatcher proves unreliable on your platform (some WSL paths, network drives). Values below 250 are clamped to the 250ms debounce floor — anything tighter would fire inside the same debounce reset cycle and waste CPU."
        },
        "claudeteam.showBackgroundCount": {
          "type": "boolean",
          "default": true,
          "description": "Show a count of unrostered (background) agents in the dashboard."
        },
        "claudeteam.showAllSessionsGlobally": {
          "type": "boolean",
          "default": false,
          "description": "Show Claude Code sessions from all workspaces, not just the current VS Code window. Default: false (only sessions whose cwd matches an open workspace folder are shown)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "agent-tree": "node dist/cli/agentTree.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:vscode": "npm run build && npm run compile:vscode-integration && node out/vscode-integration/tests/vscode-integration/runTest.js",
    "compile:vscode-integration": "tsc -p tsconfig.vscode-integration.json && node -e \"require('fs').writeFileSync('out/vscode-integration/package.json', JSON.stringify({type:'commonjs'}, null, 2))\"",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "glob": "^13.0.6",
    "jsdom": "^24.0.0",
    "mocha": "^11.7.6",
    "prettier": "^3.2.5",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3"
  }
}
